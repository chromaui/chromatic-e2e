{
  "name": "@chromatic-com/shared-e2e",
  "version": "0.9.10",
  "private": true,
  "description": "Shared Chromatic E2E",
  "repository": {
    "type": "git",
    "url": "https://github.com/chromaui/chromatic-e2e.git",
    "directory": "packages/shared"
  },
  "license": "MIT",
  "author": "Chromatic <tom@chromatic.com>",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./archive-storybook": {
      "import": {
        "types": "./dist/archive-storybook/index.d.mts",
        "default": "./dist/archive-storybook/index.mjs"
      },
      "require": {
        "types": "./dist/archive-storybook/index.d.ts",
        "default": "./dist/archive-storybook/index.js"
      }
    },
    "./utils/filePaths": {
      "import": {
        "types": "./dist/utils/filePaths.d.mts",
        "default": "./dist/utils/filePaths.mjs"
      },
      "require": {
        "types": "./dist/utils/filePaths.d.ts",
        "default": "./dist/utils/filePaths.js"
      }
    }
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "typesVersions": {
    "*": {
      ".": [
        "index.d.ts"
      ],
      "archive-storybook": [
        "dist/archive-storybook/index.d.ts"
      ],
      "utils/filePaths": [
        "dist/utils/filePaths.d.ts"
      ]
    }
  },
  "files": [
    "dist/**/*",
    "README.md",
    "*.js",
    "*.d.ts"
  ],
  "scripts": {
    "prebuild": "yarn clean",
    "build": "yarn prebuild && tsup",
    "clean": "rimraf ./dist",
    "lint": "eslint src/*",
    "prettier": "prettier",
    "test:unit": "yarn workspace @chromatic-com/shared-e2e test:unit --project shared"
  },
  "lint-staged": {
    "*.{ts,js,css,md}": "prettier --write"
  },
  "dependencies": {
    "@chromaui/rrweb-snapshot": "2.0.0-alpha.18-noAbsolute",
    "@segment/analytics-node": "2.1.3",
    "@storybook/builder-webpack5": "10.2.13",
    "@storybook/server-webpack5": "10.2.13",
    "storybook": "10.2.13"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.21.4",
    "@babel/preset-react": "^7.18.6",
    "@babel/preset-typescript": "^7.21.4",
    "@playwright/test": "^1.46.1",
    "@rrweb/types": "^2.0.0-alpha.18",
    "@testing-library/dom": "^8.1.0",
    "@testing-library/react": "^12.0.0",
    "@testing-library/user-event": "^13.2.1",
    "@types/node": "^16.4.1",
    "@types/node-fetch": "^2.6.6",
    "concurrently": "^7.0.0",
    "lint-staged": ">=10",
    "mime": "^3.0.0",
    "node-fetch": "2",
    "playwright": "^1.46.1",
    "playwright-core": "^1.46.1",
    "prettier": "^3.5.3",
    "prompts": "^2.4.2",
    "rimraf": "^3.0.2",
    "srcset": "^4.0.0",
    "ts-dedent": "^2.2.0",
    "typescript": "^5.9.3"
  }
}
