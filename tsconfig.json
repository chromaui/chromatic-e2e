{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "paths": {
      "playwright-core/types/protocol": ["node_modules/playwright-core/types/protocol.d.ts"]
    },
    "emitDecoratorMetadata": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "incremental": false,
    "isolatedModules": true,
    "strictBindCallApply": true,
    "jsx": "react",
    "lib": ["es2020", "dom"],
    "module": "preserve",
    "moduleResolution": "bundler",
    "noImplicitAny": true,
    "skipLibCheck": true,
    "target": "ES2020",
  },
  "include": ["packages/**/*.ts", "packages/**/*.tsx", "vitest.config.ts"]
}
